# Career Intelligence OS — environment template
# Copy to .env and customize (optional for MVP)

# Data directory override (default: ./data)
# DATA_DIR=./data

# Universal profile label (display only)
UNIVERSAL_PROFILE=Enterprise Technology Analyst — AI Automation, Cloud Security & Data Analytics

# DFW market focus
DEFAULT_LOCATION=Plano / Dallas

# Scoring thresholds
STRONG_FIT_THRESHOLD=75
GOOD_FIT_THRESHOLD=55

# Disclaimer flag (always show sponsorship disclaimer)
SHOW_SPONSORSHIP_DISCLAIMER=true
